@echo off
REM Локальный предпросмотр сайта МультиКрит по http:// (нужно для ES-модулей калькулятора).
REM Двойной клик: откроется браузер на лендинге, запустится мини-сервер.
REM Закрыть это окно = остановить сервер.
cd /d "%~dp0"
echo Запускаю локальный предпросмотр на http://localhost:8000/landing.html
echo Закройте это окно, чтобы остановить сервер.
start "" http://localhost:8000/landing.html
python -m http.server 8000 --bind 127.0.0.1
